{
  "expo": {
    "name": "DTF - Dynasty Trade Finder",
    "slug": "dtf-dynasty-trade-finder",
    "version": "1.8.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dtf",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fantasytradefinder.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.fantasytradefinder.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4f7cff"
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "@sentry/react-native/expo",
        {
          "organization": "dynasty-trade-finder",
          "project": "react-native"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "https://fantasy-trade-finder.onrender.com",
      "sentryDsn": "https://cd5ebfea837c8bd07ef3b749dc2daa73@o4511305516187648.ingest.us.sentry.io/4511305531326464",
      "eas": {
        "projectId": "68beb3f2-c99e-408b-b03c-1c326a64b4ec"
      }
    },
    "owner": "mattmurf77"
  }
}
