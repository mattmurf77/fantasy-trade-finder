+    const res = await submitFeedback({
+      client_id: item.id,
+      screen: item.screen,
+      severity: item.severity,
+      text: item.text,
+      client_created_at: item.created_at,
+    });
+    return {
+      synced: true,
+      server_id: res.server_id,
+      last_sync_attempt: nowIso,
+      last_sync_error: undefined,
+    };
+  } catch (err) {
+    return {
+      synced: false,
+      last_sync_attempt: nowIso,
+      last_sync_error: _describeSyncError(err),
