# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Data / runtime artifacts
/data/
*.db

# OS
.DS_Store
Thumbs.db

# Environment
.env
# Local credentials store — NEVER commit. Visible (non-dot) filename on
# purpose so it's easy to find in Finder. See CLAUDE.md "Conventions".
# Glob covers backups (secrets.local.env.bak) so a recovery copy never leaks.
secrets.local.env*

# IDE
.vscode/
.idea/

# Test / workspace artifacts
project-reorganizer-workspace/
scripts/
*.skill

# Plan-review artifacts (interactive feedback HTML + saved JSON)
notification-plan-review.html
notification-plan-feedback*.json

# QA harness scratch DBs, logs, and run artifacts (never commit DB copies)
# Covers scratch/, scratch4/, scratch_int/, scratch_cfg/, scratch_api2/, etc.
qa/**/scratch*/

# Staged subagent implementations pending 1-by-1 validation (never auto-commit)
staged-work/
mobile/test-artifacts/

# Feedback-pipeline scratch (durable outputs go to docs/feedback/items/)
feedback-workspace/*
!feedback-workspace/README.md
archive/cleanup-2026-07-19/*.bundle
